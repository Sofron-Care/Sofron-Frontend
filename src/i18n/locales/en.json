  "whyCashCare": {
    "hero": {
      "headline": "Why Cash Care Clinics Need Different Software.",
      "subtext": "Cash care physical therapy operates on a different model — but most practice management tools weren’t built for it."
    },
    "whatIs": {
      "label": "What Is Cash Care PT?",
      "text": "Cash care physical therapy clinics operate without insurance billing. Patients pay directly for services, allowing clinics to focus on outcomes, transparency, and patient experience."
    },
    "traditional": {
      "label": "Why Traditional Software Falls Short",
      "points": [
        "Built primarily for insurance workflows and claims processing.",
        "Overcomplicated systems designed for billing complexity.",
        "Poor patient experience with outdated intake flows.",
        "Limited visibility into operational performance."
      ]
    },
    "needs": {
      "label": "What Cash Care Clinics Actually Need",
      "points": [
        "Simple, flexible scheduling.",
        "Clear pricing and booking experience.",
        "Streamlined digital intake.",
        "Operational visibility without insurance complexity."
      ]
    }
  },
  "product": {
    "hero": {
      "headline": "A Modular Platform for Independent Clinics.",
