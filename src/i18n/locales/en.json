    "problem": {
      "label": "The Cash Care Reality",
      "headline": "Running a Direct-to-Patient Clinic Shouldn’t Require Five Different Tools.",
      "intro": "Cash care clinics operate differently — but most software wasn’t built with that in mind.",
      "items": [
        "Too many disconnected tools to manage scheduling, intake, and payments.",
        "Manual scheduling that leads to missed appointments and lost revenue.",
        "Clunky intake workflows that frustrate patients.",
        "Limited insight into performance and growth.",
        "Software designed for insurance billing — not direct care."
      ]
    },
    "solution": {
      "label": "The Solution",
      "headline": "One Unified Platform Built for Cash Care Clinics.",
      "intro": "Sofron replaces disconnected tools with a streamlined system designed specifically for direct-to-patient practices.",
      "features": [
        {
          "title": "Scheduling",
          "description": "Flexible clinic scheduling built for independent practitioners."
        },
        {
          "title": "Booking",
          "description": "Simple, patient-friendly booking designed to reduce no-shows."
        },
        {
          "title": "Documentation",
          "description": "Intake forms and documentation workflows tailored for cash care."
        },
        {
          "title": "Analytics",
          "description": "Clear operational visibility into performance and growth."
        }
      ]
    },
    "howItWorks": {
      "label": "How It Works",
      "headline": "Set Up. Accept Bookings. Run Your Practice.",
      "intro": "Sofron is designed to get your clinic operational quickly — without complicated onboarding.",
