  "landing": {
    "hero": {
      "title": "Practice Management for Cash-Based Health & Performance Businesses",
      "subtitle": "Scheduling, booking, intake documentation, and analytics — built for modern direct-to-client practices.",
      "pitch": "From physical therapy to personal training and recovery studios — Sofron adapts to your practice.",
      "cta_primary": "Register Interest",
      "cta_secondary": "Launch Demo"
    },
    "problem": {
      "label": "The Cash-Based Reality",
      "headline": "Running a Modern Practice Shouldn’t Require Five Different Tools.",
      "intro": "Cash-based businesses operate differently — but most software wasn’t built with that in mind.",
      "items": [
        "Too many disconnected tools to manage scheduling, intake, and payments.",
        "Manual scheduling that leads to missed appointments and lost revenue.",
        "Clunky intake workflows that frustrate clients.",
        "Limited insight into performance and growth.",
        "Software designed for insurance billing — not direct care."
      ]
    },
    "solution": {
      "label": "The Solution",
      "headline": "One Unified Platform Built for Cash-Based Practices.",
      "intro": "Sofron replaces disconnected tools with a streamlined system designed for direct-to-client businesses.",
      "features": [
        {
          "title": "Scheduling",
          "description": "Flexible scheduling built for independent practitioners and small teams."
        },
        {
          "title": "Booking",
          "description": "Simple, client-friendly booking designed to reduce no-shows."
        },
        {
          "title": "Documentation",
          "description": "Intake forms and workflows tailored to modern service-based businesses."
        },
        {
          "title": "Analytics",
          "description": "Clear visibility into performance, revenue, and growth."
        }
      ]
    },
    "howItWorks": {
      "label": "How It Works",
      "headline": "Set Up. Accept Bookings. Run Your Business.",
      "intro": "Sofron is designed to get you operational quickly — without complicated onboarding.",
      "steps": [
        {
          "title": "Set Up Your Business",
          "description": "Configure services, availability, pricing, and intake workflows in minutes."
        },
        {
          "title": "Accept Client Bookings",
          "description": "Clients book seamlessly through a simple, easy-to-use scheduling experience."
        },
        {
          "title": "Run and Optimize",
          "description": "Track performance, manage documentation, and operate with full visibility."
        }
      ]
    },
    "cta": {
      "headline": "Built for Independent Practices.",
      "subtext": "Sofron is currently in pre-release. Explore the demo or register your interest to receive early updates.",
      "primary": "Register Interest",
      "secondary": "Launch Demo"
    }
  },
  "whyCashCare": {
    "hero": {
      "headline": "Why Cash-Based Practices Need Different Software.",
      "subtext": "Direct-to-client businesses operate differently — but most tools weren’t built for that model."
    },
    "whatIs": {
      "label": "What Is a Cash-Based Practice?",
      "text": "Cash-based practices operate without insurance billing. Clients pay directly for services, allowing businesses to focus on outcomes, transparency, and experience."
    },
    "traditional": {
      "label": "Why Traditional Software Falls Short",
      "points": [
        "Built primarily for insurance workflows and claims processing.",
        "Overcomplicated systems designed for billing complexity.",
        "Poor patient experience with outdated intake flows.",
        "Limited visibility into operational performance."
      ]
    },
    "needs": {
      "label": "What Modern Practices Actually Need",
      "points": [
        "Simple, flexible scheduling.",
        "Clear pricing and booking experience.",
        "Streamlined digital intake.",
        "Operational visibility without unnecessary complexity."
      ]
    }
  },
  "product": {
    "hero": {
      "headline": "A Modular Platform for Independent Practices.",
      "subtext": "Use what you need. Expand as you grow. Sofron adapts to the way modern service-based businesses operate."
